<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-center">Dashboard Administrativo</h2>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm p-3 text-center border-primary">
                <h5 class="mb-1">Pedidos (historico)</h5>
                <h2 class="text-primary mb-0">{{totalOrders}}</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm p-3 text-center border-info">
                <h5 class="mb-1">Pedidos de hoy</h5>
                <h2 class="text-info mb-0">{{todayOrders}}</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm p-3 text-center border-dark">
                <h5 class="mb-1">Productos creados</h5>
                <h2 class="text-dark mb-0">{{totalProducts}}</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm p-3 border-success">
                <h5 class="text-center">Comercios</h5>
                <p class="mb-1 text-center"><strong>Activos:</strong> {{activeCommerces}}</p>
                <p class="mb-0 text-center"><strong>Inactivos:</strong> {{inactiveCommerces}}</p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm p-3 border-warning">
                <h5 class="text-center">Clientes</h5>
                <p class="mb-1 text-center"><strong>Activos:</strong> {{activeClients}}</p>
                <p class="mb-0 text-center"><strong>Inactivos:</strong> {{inactiveClients}}</p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm p-3 border-danger">
                <h5 class="text-center">Delivery</h5>
                <p class="mb-1 text-center"><strong>Activos:</strong> {{activeDeliveries}}</p>
                <p class="mb-0 text-center"><strong>Inactivos:</strong> {{inactiveDeliveries}}</p>
            </div>
        </div>
    </div>
</div>
