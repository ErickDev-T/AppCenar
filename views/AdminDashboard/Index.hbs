<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-center">Dashboard Administrativo</h2>
        </div>
    </div>

    <div class="row">

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-3 text-center border-primary">
                <h5>Total de Pedidos</h5>
                <h2 class="text-primary">{{totalOrders}}</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-3 text-center border-success">
                <h5>Total de Comercios</h5>
                <h2 class="text-success">{{totalCommerce}}</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-3 text-center border-warning">
                <h5>Total de Clientes</h5>
                <h2 class="text-warning">{{totalClients}}</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-3 text-center border-danger">
                <h5>Total de Deliverys</h5>
                <h2 class="text-danger">{{totalDelivery}}</h2>
            </div>
        </div>

    </div>

</div>