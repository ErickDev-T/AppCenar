<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12">
            <h2>Delivery Dashboard</h2>
        </div>
    </div>

    {{#if hasDeliveries}}

    <div class="row">

        {{#each deliveriesList}}

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm p-3">

                <!-- 🔹 Nombre -->
                <h5 class="text-center">
                    {{this.name}} {{this.lastName}}
                </h5>

                <!-- 🔹 Email -->
                <p class="text-center mb-1">
                    <strong>Email:</strong> {{this.email}}
                </p>

                <!-- 🔹 Teléfono -->
                <p class="text-center mb-2">
                    <strong>Teléfono:</strong> {{this.phone}}
                </p>

                <!-- 🔹 Estado -->
                <p class="text-center mb-2">
                    <strong>Estado:</strong> 
                    {{#if this.isActive}}
                        <span class="text-success">Activo</span>
                    {{else}}
                        <span class="text-danger">Inactivo</span>
                    {{/if}}
                </p>

                <form action="/delivery/DeliveryDashboardAdmin" method="post">

                    <input type="hidden" name="deliveryId" value="{{this._id}}">
                    <input type="hidden" name="status" value="{{#if this.isActive}}false{{else}}true{{/if}}">

                    <div class="d-flex justify-content-center">

                        <button type="submit" class="btn btn-sm {{#if this.isActive}}btn-danger{{else}}btn-success{{/if}}">

                            {{#if this.isActive}}Inactivar{{else}}Activar{{/if}}

                        </button>

                    </div>

                </form>

            </div>

        </div>

        {{/each}}

    </div>

    {{else}}

    <div class="text-center mt-5">
        <h3 class="text-muted">No hay deliveries registrados</h3>
    </div>

    {{/if}}

</div>