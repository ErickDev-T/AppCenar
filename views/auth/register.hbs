<div class="row justify-content-center mt-4">
  <div class="col-12 col-sm-10 col-md-8 col-lg-6">
    <div class="card shadow-sm border rounded-3">
      
      <div class="card-header bg-danger text-white text-center py-2">
        <h1 class="h4 mb-0">
          <i class="bi bi-person-plus-fill me-2"></i>Crear cuenta
        </h1>
      </div>

      <div class="card-body p-3 p-md-4">
        <p class="text-muted mb-3 small">Completa el formulario para registrarte</p>

        {{#if errors.length}}
          <div class="alert alert-danger py-2" role="alert">
            <ul class="mb-0 small">
              {{#each errors}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
        {{/if}}

        <form action="/user/register" method="POST" enctype="multipart/form-data" novalidate>
          <div class="row g-2">

            <div class="col-12 col-md-6">
              <label for="name" class="form-label mb-1">Nombre</label>
              <input
                id="name"
                name="name"
                type="text"
                class="form-control"
                value="{{formData.name}}"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="lastName" class="form-label mb-1">Apellido</label>
              <input
                id="lastName"
                name="lastName"
                type="text"
                class="form-control"
                value="{{formData.lastName}}"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="username" class="form-label mb-1">Usuario</label>
              <input
                id="username"
                name="username"
                type="text"
                class="form-control"
                value="{{formData.username}}"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="email" class="form-label mb-1">Correo</label>
              <input
                id="email"
                name="email"
                type="email"
                class="form-control"
                value="{{formData.email}}"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="phone" class="form-label mb-1">Teléfono</label>
              <input
                id="phone"
                name="phone"
                type="text"
                class="form-control"
                value="{{formData.phone}}"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="role" class="form-label mb-1">Rol</label>
              <select id="role" name="role" class="form-select" required>
                <option value="">Selecciona un rol</option>
                <option value="client" {{#if (eq formData.role "client")}}selected{{/if}}>Cliente</option>
                <option value="delivery" {{#if (eq formData.role "delivery")}}selected{{/if}}>Delivery</option>
              </select>
            </div>

            <div class="col-12">
              <label for="profileImage" class="form-label mb-1">Foto de perfil</label>
              <input
                id="profileImage"
                name="profileImage"
                type="file"
                class="form-control"
                accept="image/*"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="password" class="form-label mb-1">Contraseña</label>
              <input
                id="password"
                name="password"
                type="password"
                class="form-control"
                minlength="8"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="confirmPassword" class="form-label mb-1">Confirmar contraseña</label>
              <input
                id="confirmPassword"
                name="confirmPassword"
                type="password"
                class="form-control"
                minlength="8"
                required
              />
            </div>
          </div>

          <div class="my-3" ></div> 

          <div class="d-flex justify-content-between gap-2">
            <a href="/user/login" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-box-arrow-in-right me-1"></i>Ya tengo cuenta
            </a>

            <button type="submit" class="btn btn-danger btn-sm px-3">
              <i class="bi bi-person-check-fill me-1"></i>Crear cuenta
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>