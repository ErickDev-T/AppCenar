<div class="d-flex justify-content-center mt-5">
  <div class="col-12 col-md-4">
    <div class="card shadow-sm">

      <div class="card-header bg-warning text-dark">
        <h5 class="text-center mb-0"><i class="bi bi-key"></i> Restablecer contraseña</h5>
      </div>

      <div class="card-body">

        {{#if errors.length}}
          <div class="alert alert-danger py-2" role="alert">
            <ul class="mb-0 small">
              {{#each errors}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
        {{/if}}

        {{#if success}}
          <div class="alert alert-success py-2"><i class="bi bi-envelope-check"></i> Revise su correo </div>
        {{/if}}

        <p class="text-muted small mb-3">Ingresa tu usuario o correo y te enviaremos un enlace para restablecer tu contraseña.</p>

        <form action="/user/forgot-password" method="POST">
          <div class="mb-3">
            <label for="identifier" class="form-label">Usuario o correo:</label>
            <input type="text" class="form-control" id="identifier" name="identifier" value="{{formData.identifier}}" required />
          </div>

          <div>
            <button type="submit" class="btn btn-warning float-end"><i class="bi bi-send"></i> Enviar enlace</button>
            <a href="/user/login" class="btn btn-outline-secondary float-end me-2"><i class="bi bi-arrow-left"></i> Volver</a>
          </div>
        </form>

      </div>
    </div>
  </div>
</div>
