<div class="container mt-4">
    <div class="row d-flex justify-content-center">

        <div class="col-12 col-sm-6 col-md-5">

            <div class="card shadow">

                <div class="card-header bg-primary text-light text-center">
                    <h3 class="h3">
                        {{#if editMode}} Editar Configuración {{else}} Crear Configuración {{/if}}
                    </h3>
                </div>

                <div class="card-body">

                    <form action="/configurations/{{#if editMode}}edit{{else}}save{{/if}}" method="post">

                        <div class="mb-3">
                            <label class="form-label">ITBIS:</label>
                            <input type="number"
                                   class="form-control"
                                   name="itbis"
                                   required
                                   step="0.01"
                                   min="0"
                                   value="{{#if editMode}}{{configuration.itbis}}{{/if}}">
                        </div>

                        {{#if editMode}}
                        <input type="hidden" name="id" value="{{configuration._id}}">
                        {{/if}}

                        <div class="d-flex justify-content-end">

                            <a href="/configurations" class="btn btn-warning me-2">
                                Volver
                            </a>

                            <button type="submit" class="btn btn-primary">
                                {{#if editMode}} Actualizar {{else}} Guardar {{/if}}
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>
</div>