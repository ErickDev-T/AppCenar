<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12 col-sm-4">
            <a class="btn btn-success w-100" href="/configurations/save">
                Nueva Configuración
            </a>
        </div>
    </div>

    {{#if hasconfiguration}}

    <div class="row">

        {{#each configurationList}}

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm p-3">

                <h5 class="text-center">
                    Configuración
                </h5>

                <p class="text-center mb-2">
                    <strong>ITBIS:</strong> {{this.itbis}}%
                </p>

                <div class="d-flex justify-content-center mt-2">

                    <a href="/configuration/edit/{{this._id}}" 
                       class="btn btn-primary btn-sm">
                        Editar
                    </a>

                </div>

            </div>

        </div>

        {{/each}}

    </div>

    {{else}}

    <div class="text-center mt-5">
        <h3 class="text-muted">No hay configuraciones</h3>
    </div>

    {{/if}}

</div>