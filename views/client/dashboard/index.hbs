<div class="container py-4">

  <h4 class="mb-1">Hola, {{user.name}}</h4>
  <p class="text-muted small mb-4">¿Qué vas a pedir hoy?</p>

   {{#if errors.length}}
      <div class="alert alert-danger py-2">
        {{#each errors}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

    {{#if success.length}}
      <div class="alert alert-success py-2">
        {{#each success}}
          <p class="mb-0">{{this}}</p>
        {{/each}}
      </div>
    {{/if}}

  {{#if hasCommerceTypes}}
    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3">
      {{#each commerceTypes}}
        <div class="col">
          <a href="/client/commerces/{{this._id}}" class="text-decoration-none">
            <div class="card h-100 text-center shadow-sm border rounded-3 p-2">
              <div class="card-body p-2">
                {{#if this.iconUrl}}
                <img src="{{this.iconUrl}}" alt="{{this.name}}" class="img-fluid mb-2" width="48" height="48" />
                {{else}}
                {{#if this.iconClass}}
                <i class="{{this.iconClass}} d-block mb-2" style="font-size: 2rem;"></i>
                {{/if}}
                {{/if}}
                <p class="small fw-semibold text-dark mb-0">{{this.description}}</p>
              </div>
            </div>
          </a>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="alert alert-info py-2 small">No hay tipos de comercios disponibles por el momento.</div>
  {{/if}}

</div>
