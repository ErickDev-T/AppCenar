<div class="container py-4">

  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/client/dashboard" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left"></i> Volver
    </a>
    {{#if commerce.logoUrl}}
      <img src="{{commerce.logoUrl}}" alt="{{commerce.name}}"
        width="48" height="48" class="rounded-circle" style="object-fit:cover;">
    {{/if}}
    <h4 class="mb-0">{{commerce.name}}</h4>
  </div>

  <div class="row g-4">

    <div class="col-lg-8">
      {{#if hasCategories}}
        {{#each categories}}
          <h5 class="fw-bold mt-3 mb-2 border-bottom pb-1">{{this.name}}</h5>
          {{#each this.items}}
            <div class="card mb-2 border rounded-3">
              <div class="card-body d-flex align-items-center gap-3 py-2">
                {{#if this.imageUrl}}
                  <img src="{{this.imageUrl}}" alt="{{this.name}}"
                    width="72" height="72" class="rounded" style="object-fit:cover; flex-shrink:0;">
                {{/if}}
                <div class="flex-grow-1">
                  <strong>{{this.name}}</strong>
                  <p class="text-muted small mb-1">{{this.description}}</p>
                  <span class="fw-semibold text-success">{{this.priceLabel}}</span>
                </div>
                {{#if (includes ../../../cartIds this._id)}}
                  <button class="btn btn-sm btn-secondary" disabled>Agregado</button>
                {{else}}
                  <form action="/client/cart/add" method="POST">
                    <input type="hidden" name="productId" value="{{this._id}}" />
                    <input type="hidden" name="name" value="{{this.name}}" />
                    <input type="hidden" name="price" value="{{this.price}}" />
                    <input type="hidden" name="commerceId" value="{{../../commerce._id}}" />
                    <button type="submit" class="btn btn-sm btn-success">Agregar</button>
                  </form>
                {{/if}}
              </div>
            </div>
          {{/each}}
        {{/each}}
      {{else}}
        <div class="alert alert-info">Este comercio no tiene productos disponibles.</div>
      {{/if}}
    </div>

    <div class="col-lg-4">
      <div class="card border rounded-3 p-3 sticky-top" style="top: 80px;">
        <h5 class="fw-bold mb-3">Mi pedido</h5>

        {{#if cart.hasItems}}
          {{#each cart.items}}
            <div class="d-flex justify-content-between align-items-center mb-2 small">
              <span>{{this.name}}</span>
              <form action="/client/cart/remove" method="POST">
                <input type="hidden" name="productId" value="{{this.productId}}" />
                <input type="hidden" name="commerceId" value="{{../commerce._id}}" />
                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1">✕</button>
              </form>
            </div>
          {{/each}}

          <hr>
          <div class="d-flex justify-content-between small">
            <span>Subtotal</span><span>{{cart.subtotalLabel}}</span>
          </div>
          <div class="d-flex justify-content-between small text-muted">
            <span>ITBIS ({{itbisRate}}%)</span><span>{{cart.itbisLabel}}</span>
          </div>
          <div class="d-flex justify-content-between fw-bold mt-1">
            <span>Total</span><span>{{cart.totalLabel}}</span>
          </div>

          <a href="/client/checkout/{{commerce._id}}" class="btn btn-success w-100 mt-3">
            Continuar <i class="bi bi-arrow-right"></i>
          </a>
          <form action="/client/cart/clear" method="POST" class="mt-2">
            <input type="hidden" name="commerceId" value="{{commerce._id}}" />
            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
              Vaciar carrito
            </button>
          </form>
        {{else}}
          <p class="text-muted small">Tu pedido está vacío</p>
        {{/if}}
      </div>
    </div>

  </div>
</div>