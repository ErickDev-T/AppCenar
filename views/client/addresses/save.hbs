<div class="d-flex justify-content-center align-items-center py-5" style="min-height: 100vh; background-color: #0d3b3b;">
  <div class="p-4 rounded-4" style="background-color: #f0f0f0; width: 100%; max-width: 480px;">

    <h4 class="fw-bold mb-1">{{#if editMode}}Editar dirección{{else}}Nueva dirección{{/if}}</h4>
    <p class="text-muted small mb-4">{{#if editMode}}Modifica los datos de tu dirección{{else}}Agrega una nueva dirección de entrega{{/if}}</p>

    <form method="POST" action="/address/{{#if editMode}}edit{{else}}create{{/if}}">

      <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input type="text" class="form-control" name="Name"
          value="{{#if editMode}}{{address.name}}{{/if}}" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Descripción</label>
        <textarea class="form-control" name="Description" rows="2"
          required>{{#if editMode}}{{address.description}}{{/if}}</textarea>
      </div>

      {{#if editMode}}
        <input type="hidden" name="AddressId" value="{{address._id}}" />
      {{/if}}

      <div class="d-flex gap-2 mt-4">
        <a href="/client/addresses" class="btn btn-outline-secondary w-50">
          <i class="bi bi-arrow-left"></i> Volver
        </a>
        <button type="submit" class="btn w-50 text-white" style="background-color: #1a7a7a;">
          <i class="bi bi-floppy"></i> Guardar
        </button>
      </div>

    </form>

  </div>
</div>