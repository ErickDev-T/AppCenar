<section class="py-3">
  <h1 class="h4 mb-3">Mis pedidos</h1>

  {{#if loadError}}
  <div class="alert alert-danger py-2 mb-3">No se pudieron cargar tus pedidos.</div>
  {{/if}}

  {{#if hasOrders}}
  <div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
      <thead>
        <tr>
          <th>Pedido</th>
          <th>Comercio</th>
          <th>Productos</th>
          <th>Estado</th>
          <th>Total</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody>
        {{#each ordersList}}
        <tr>
          <td>#{{shortId}}</td>
          <td>{{commerceName}}</td>
          <td>{{productsCount}}</td>
          <td>
            {{#if (eq status "pendiente")}}
              <span class="badge text-bg-warning">Pendiente</span>
            {{/if}}
            {{#if (eq status "en proceso")}}
              <span class="badge text-bg-primary">En proceso</span>
            {{/if}}
            {{#if (eq status "completado")}}
              <span class="badge text-bg-success">Completado</span>
            {{/if}}
          </td>
          <td>{{totalLabel}}</td>
          <td>{{createdAtLabel}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="mb-0">No hay pedidos para mostrar.</p>
  {{/if}}
</section>
