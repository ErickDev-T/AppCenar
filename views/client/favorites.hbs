<div class="d-flex justify-content-center align-items-start py-5" style="min-height: 100vh; background-color: #0d3b3b;">
  <div class="p-4 rounded-4" style="background-color: #f0f0f0; width: 100%; max-width: 620px;">

    <h4 class="fw-bold mb-1">Mis favoritos</h4>
    <p class="text-muted small mb-4">Comercios que has marcado como favoritos</p>

    {{#if hasFavorites}}
      <div class="d-flex flex-column gap-2">
        {{#each favoritesList}}
          <div class="p-3 rounded-3 border d-flex align-items-center gap-3" style="background-color: #fff;">
            <a href="/orders/create/{{this.commerceId._id}}">
              {{#if this.commerceId.logo}}
                <img src="{{this.commerceId.logo}}" alt="logo" width="48" height="48"
                  class="rounded-circle" style="object-fit: cover;">
              {{else}}
                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                  style="width:48px; height:48px;">
                  <i class="bi bi-shop text-white"></i>
                </div>
              {{/if}}
            </a>
            <span class="flex-grow-1 fw-semibold text-dark">{{this.commerceId.name}}</span>
            <form method="POST" action="/favorite/remove">
              <input type="hidden" name="FavoriteId" value="{{this._id}}" />
              <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-heart-fill"></i> Remover
              </button>
            </form>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No tienes comercios favoritos aún.
      </div>
    {{/if}}

  </div>
</div>