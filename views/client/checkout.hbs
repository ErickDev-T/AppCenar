<div class="container py-4">

  <div class="d-flex align-items-center gap-2 mb-4">
    <a href="/client/catalogue/{{commerce._id}}" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <h4 class="mb-0">Confirmar pedido</h4>
  </div>

  {{#if hasAddresses}}
    <div class="row g-4">

      <div class="col-lg-7">
        <div class="card border rounded-3 p-3">
          <h5 class="fw-bold mb-3">Selecciona una dirección</h5>
          <form action="/client/checkout" method="POST" id="checkoutForm">
            <input type="hidden" name="commerceId" value="{{commerce._id}}" />

            {{#each addresses}}
              <div class="form-check border rounded-3 p-3 mb-2">
                <input class="form-check-input" type="radio" name="addressId" id="addr-{{this._id}}" value="{{this._id}}" required />
                <label class="form-check-label w-100" for="addr-{{this._id}}">
                  <span class="fw-semibold">{{this.name}}</span>
                  <p class="text-muted small mb-0">{{this.description}}</p>
                </label>
              </div>
            {{/each}}

            <button type="submit" class="btn btn-success w-100 mt-3">
              <i class="bi bi-bag-check me-1"></i>Realizar pedido
            </button>
          </form>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="card border rounded-3 p-3">
          <div class="d-flex align-items-center gap-3 mb-3">
            {{#if commerce.logoUrl}}
              <img src="{{commerce.logoUrl}}" alt="{{commerce.name}}" width="48" height="48" class="rounded-circle" />
            {{/if}}
            <h5 class="fw-bold mb-0">{{commerce.name}}</h5>
          </div>

          {{#each cart.items}}
            <div class="d-flex justify-content-between small mb-1">
              <span>{{this.name}}</span>
            </div>
          {{/each}}

          <hr />

          <div class="d-flex justify-content-between small">
            <span>Subtotal</span><span>{{cart.subtotalLabel}}</span>
          </div>
          <div class="d-flex justify-content-between small text-muted">
            <span>ITBIS ({{itbisRate}}%)</span><span>{{cart.itbisLabel}}</span>
          </div>
          <div class="d-flex justify-content-between fw-bold mt-1">
            <span>Total</span><span>{{cart.totalLabel}}</span>
          </div>
        </div>
      </div>

    </div>
  {{else}}
    <div class="alert alert-warning">
      No tienes direcciones registradas.
      <a href="/client/addresses" class="alert-link">Agregar una dirección</a>
    </div>
  {{/if}}

</div>