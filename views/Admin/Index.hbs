<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12 col-sm-4">
            <a class="btn btn-success w-100" href="/Admin/create">
                Nuevo Administrador
            </a>
        </div>
    </div>

    {{#if hasAdmin}}

    <div class="row">

        {{#each adminList}}

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm p-3">

                <h5 class="text-center">
                    {{this.name}} {{this.lastName}}
                </h5>

                <p class="text-center mb-1">
                    <strong>Usuario:</strong> {{this.username}}
                </p>

                <p class="text-center mb-1">
                    <strong>Email:</strong> {{this.email}}
                </p>

                <p class="text-center mb-2">
                    <strong>Cédula:</strong> {{this.cedula}}
                </p>

                <p class="text-center mb-2">
                    <strong>Estado:</strong> 
                    {{#if this.isActive}}
                        <span class="text-success">Activo</span>
                    {{else}}
                        <span class="text-danger">Inactivo</span>
                    {{/if}}
                </p>

                <div class="d-flex justify-content-between mt-2">

                    <a href="/admin/edit/{{this._id}}" 
                       class="btn btn-primary btn-sm">
                        Editar
                    </a>

                    <form action="/admin/status/{{this._id}}" method="post">

                        <input type="hidden" name="status" value="{{#if this.isActive}}false{{else}}true{{/if}}">

                        <button type="submit" 
                                class="btn btn-sm {{#if this.isActive}}btn-danger{{else}}btn-success{{/if}}"
                                onclick="return confirm('¿Seguro que deseas cambiar el estado de este administrador?')">

                            {{#if this.isActive}}Inactivar{{else}}Activar{{/if}}

                        </button>

                    </form>

                </div>

            </div>

        </div>

        {{/each}}

    </div>

    {{else}}

    <div class="text-center mt-5">
        <h3 class="text-muted">No hay administradores</h3>
    </div>

    {{/if}}

</div>