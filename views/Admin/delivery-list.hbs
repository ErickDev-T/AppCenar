<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-center">Dashboard de Delivery</h2>
        </div>
    </div>

    {{#if hasDeliveries}}

    <div class="row">

        {{#each deliveriesList}}

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm p-3">

                <h5 class="text-center">
                    {{this.name}} {{this.lastName}}
                </h5>

                <p class="text-center mb-1">
                    <strong>Email:</strong> {{this.email}}
                </p>

                <p class="text-center mb-1">
                    <strong>Teléfono:</strong> {{this.phone}}
                </p>

                <p class="text-center mb-1">
                    <strong>Órdenes asignadas:</strong> {{this.ordersCount}}
                </p>

                <p class="text-center mb-2">
                    <strong>Estado:</strong>

                    {{#if this.isActive}}
                        <span class="text-success">Activo</span>
                    {{else}}
                        <span class="text-danger">Inactivo</span>
                    {{/if}}
                </p>

                <div class="d-flex justify-content-center mt-2">

                    <form action="/delivery/status/{{this._id}}" method="post">

                        <input
                            type="hidden"
                            name="status"
                            value="{{#if this.isActive}}false{{else}}true{{/if}}"
                        >

                        <button
                            type="submit"
                            class="btn btn-sm {{#if this.isActive}}btn-danger{{else}}btn-success{{/if}}"
                            onclick="return confirm('¿Seguro que deseas cambiar el estado de este delivery?')"
                        >
                            {{#if this.isActive}}
                                Inactivar
                            {{else}}
                                Activar
                            {{/if}}
                        </button>

                    </form>

                </div>

            </div>

        </div>

        {{/each}}

    </div>

    {{else}}

    <div class="text-center mt-5">
        <h3 class="text-muted">No hay deliverys registrados</h3>
    </div>

    {{/if}}

</div>