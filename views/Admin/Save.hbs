<div class="container mt-4">
    <div class="row d-flex justify-content-center">

        <div class="col-12 col-sm-6 col-md-5">

            <div class="card shadow">

                <div class="card-header bg-primary text-light text-center">
                    <h3 class="h3">
                        {{#if editMode}} Editar Administrador {{else}} Crear Administrador {{/if}}
                    </h3>
                </div>

                <div class="card-body">

                    <form action="/admin/{{#if editMode}}edit{{else}}create{{/if}}" method="post">

                        <div class="mb-3">
                            <label class="form-label">Nombre:</label>
                            <input type="text"
                                   class="form-control"
                                   name="name"
                                   required
                                   value="{{#if editMode}}{{admin.name}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Apellido:</label>
                            <input type="text"
                                   class="form-control"
                                   name="lastName"
                                   required
                                   value="{{#if editMode}}{{admin.lastName}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Cédula:</label>
                            <input type="text"
                                   class="form-control"
                                   name="cedula"
                                   required
                                   value="{{#if editMode}}{{admin.cedula}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Correo:</label>
                            <input type="email"
                                   class="form-control"
                                   name="email"
                                   required
                                   value="{{#if editMode}}{{admin.email}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Usuario:</label>
                            <input type="text"
                                   class="form-control"
                                   name="username"
                                   required
                                   value="{{#if editMode}}{{admin.username}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Contraseña:</label>
                            <input type="password"
                                   class="form-control"
                                   name="password"
                                   required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Confirmar contraseña:</label>
                            <input type="password"
                                   class="form-control"
                                   name="confirmPassword"
                                   required>
                        </div>

                        {{#if editMode}}
                        <input type="hidden" name="id" value="{{admin._id}}">
                        {{/if}}

                        <div class="d-flex justify-content-end">

                            <a href="/admin" class="btn btn-warning me-2">
                                Volver
                            </a>

                            <button type="submit" class="btn btn-primary">
                                {{#if editMode}} Actualizar {{else}} Guardar {{/if}}
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>
</div>