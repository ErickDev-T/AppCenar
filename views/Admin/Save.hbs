<div class="container mt-4">
    <div class="row d-flex justify-content-center">

        <div class="col-12 col-sm-8 col-md-6 col-lg-5">

            <div class="card shadow">

                <div class="card-header bg-primary text-light text-center">
                    <h3 class="h3 mb-0">
                        {{#if editMode}}
                            Editar Administrador
                        {{else}}
                            Crear Administrador
                        {{/if}}
                    </h3>
                </div>

                <div class="card-body">

                    {{#if errors}}
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                {{#each errors}}
                                    <li>{{this}}</li>
                                {{/each}}
                            </ul>
                        </div>
                    {{/if}}

                    <form action="/Admin/{{#if editMode}}edit{{else}}create{{/if}}" method="post">

                        <div class="mb-3">
                            <label class="form-label">Nombre:</label>
                            <input
                                type="text"
                                class="form-control"
                                name="name"
                                required
                                value="{{#if editMode}}{{admin.name}}{{else}}{{formData.name}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Apellido:</label>
                            <input
                                type="text"
                                class="form-control"
                                name="lastName"
                                required
                                value="{{#if editMode}}{{admin.lastName}}{{else}}{{formData.lastName}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Cédula:</label>
                            <input
                                type="text"
                                class="form-control"
                                name="cedula"
                                required
                                value="{{#if editMode}}{{admin.cedula}}{{else}}{{formData.cedula}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Correo:</label>
                            <input
                                type="email"
                                class="form-control"
                                name="email"
                                required
                                value="{{#if editMode}}{{admin.email}}{{else}}{{formData.email}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Usuario:</label>
                            <input
                                type="text"
                                class="form-control"
                                name="username"
                                required
                                value="{{#if editMode}}{{admin.username}}{{else}}{{formData.username}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Teléfono:</label>
                            <input
                                type="text"
                                class="form-control"
                                name="phone"
                                required
                                value="{{#if editMode}}{{admin.phone}}{{else}}{{formData.phone}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                {{#if editMode}}
                                    Nueva contraseña:
                                {{else}}
                                    Contraseña:
                                {{/if}}
                            </label>
                            <input
                                type="password"
                                class="form-control"
                                name="password"
                                required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                {{#if editMode}}
                                    Confirmar nueva contraseña:
                                {{else}}
                                    Confirmar contraseña:
                                {{/if}}
                            </label>
                            <input
                                type="password"
                                class="form-control"
                                name="confirmPassword"
                                required>
                        </div>

                        {{#if editMode}}
                            <input type="hidden" name="id" value="{{admin._id}}">
                        {{/if}}

                        <div class="d-flex justify-content-end">

                            <a href="/Admin" class="btn btn-warning me-2">
                                Volver
                            </a>

                            <button type="submit" class="btn btn-primary">
                                {{#if editMode}}
                                    Actualizar
                                {{else}}
                                    Guardar
                                {{/if}}
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>
</div>
