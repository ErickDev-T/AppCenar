<section class="py-3">
  <h1 class="h4 mb-3">Home del delivery</h1>

  {{#if loadError}}
  <div class="alert alert-danger py-2 mb-3">No se pudieron cargar los pedidos asignados.</div>
  {{/if}}

  {{#if hasOrders}}
  <div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
      <thead>
        <tr>
          <th>Logo</th>
          <th>Estado</th>
          <th>Comercio</th>
          <th>Total</th>
          <th>Cantidad de productos</th>
          <th>Fecha y hora</th>
          <th>Detalle</th>
        </tr>
      </thead>
      <tbody>
        {{#each ordersList}}
        <tr
          role="link"
          tabindex="0"
          style="cursor: pointer;"
          onclick="window.location.href='/delivery/orders/{{id}}'"
          onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); window.location.href='/delivery/orders/{{id}}'; }"
        >
          <td>
            {{#if commerceLogoUrl}}
            <img
              src="{{commerceLogoUrl}}"
              alt="Logo {{commerceName}}"
              class="rounded"
              style="width: 44px; height: 44px; object-fit: cover;"
            />
            {{else}}
            <span class="badge text-bg-secondary"><i class="bi bi-shop"></i></span>
            {{/if}}
          </td>
          <td>
            <span class="badge {{statusBadgeClass}}">{{statusLabel}}</span>
          </td>
          <td>{{commerceName}}</td>
          <td>{{totalLabel}}</td>
          <td>{{productsCount}}</td>
          <td>{{createdAtLabel}}</td>
          <td>
            <a href="/delivery/orders/{{id}}" class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation();">
              Ver detalle
            </a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="mb-0">No hay pedidos asignados para mostrar.</p>
  {{/if}}
</section>
