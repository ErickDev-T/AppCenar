<div class="container mt-4">
    <div class="row d-flex justify-content-center">

        <div class="col-12 col-sm-6 col-md-5">

            <div class="card shadow">

                <div class="card-header bg-primary text-light text-center">
                    <h3 class="h3">
                        {{#if editMode}} Editar Tipo de Comercio {{else}} Crear Tipo de Comercio {{/if}}
                    </h3>
                </div>

                <div class="card-body">

                    {{#if errors.length}}
                    <div class="alert alert-danger py-2">
                        {{#each errors}}
                        <p class="mb-0">{{this}}</p>
                        {{/each}}
                    </div>
                    {{/if}}

                    <form action="/commerceType/{{#if editMode}}edit{{else}}save{{/if}}" method="post" enctype="multipart/form-data">

                        <div class="mb-3">
                            <label class="form-label">Nombre:</label>
                            <input type="text"
                                   class="form-control"
                                   name="name"
                                   required
                                   value="{{#if editMode}}{{commerceType.name}}{{else}}{{formData.name}}{{/if}}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Descripcion:</label>
                            <textarea class="form-control"
                                      name="description"
                                      rows="3"
                                      required>{{#if editMode}}{{commerceType.description}}{{else}}{{formData.description}}{{/if}}</textarea>
                        </div>

                        <div class="mb-3">
                            <label for="icon" class="form-label">Icono del tipo (imagen):</label>
                            <input type="file"
                                   id="icon"
                                   class="form-control"
                                   name="icon"
                                   accept="image/*"
                                   {{#unless editMode}}required{{/unless}}>
                            {{#if editMode}}
                            <small class="text-muted">Si no subes un icono nuevo, se mantiene el actual.</small>
                            {{/if}}
                        </div>

                        {{#if editMode}}
                        <div class="mb-3 text-center">
                            <p class="mb-2 fw-semibold">Icono actual</p>
                            {{#if commerceType.iconUrl}}
                            <img src="{{commerceType.iconUrl}}" alt="{{commerceType.name}}" width="60" height="60" class="rounded"
                                 style="object-fit: cover;">
                            {{else}}
                            {{#if commerceType.iconClass}}
                            <i class="{{commerceType.iconClass}}" style="font-size: 48px;"></i>
                            {{else}}
                            <span class="text-muted">Sin icono actual</span>
                            {{/if}}
                            {{/if}}
                        </div>
                        <input type="hidden" name="id" value="{{commerceType._id}}">
                        {{/if}}

                        <div class="d-flex justify-content-end">

                            <a href="/commerceType" class="btn btn-warning me-2">
                                Volver
                            </a>

                            <button type="submit" class="btn btn-primary">
                                {{#if editMode}} Actualizar {{else}} Guardar {{/if}}
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>
</div>
