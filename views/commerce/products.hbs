<section class="py-3">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h4 mb-0">Mantenimiento de productos</h1>
    <a href="/commerce/products/new" class="btn btn-primary">Crear producto</a>
  </div>

  {{#each successMessages}}
  <div class="alert alert-success py-2 mb-2">{{this}}</div>
  {{/each}}

  {{#if errors.length}}
  <div class="alert alert-danger py-2 mb-3">
    <ul class="mb-0">
      {{#each errors}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  <div class="card">
    <div class="card-body p-0">
      {{#if hasProducts}}
      <div class="table-responsive">
        <table class="table table-striped mb-0 align-middle">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Imagen</th>
              <th>Descripcion</th>
              <th>Categoria</th>
              <th>Precio</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each productsList}}
            <tr>
              <td>{{name}}</td>
              <td>
                {{#if imageUrl}}
                <img
                  src="{{imageUrl}}"
                  alt="Producto {{name}}"
                  class="rounded"
                  style="width: 56px; height: 56px; object-fit: cover;"
                />
                {{else}}
                <span class="text-muted"><i class="bi bi-image"></i> Sin foto</span>
                {{/if}}
              </td>
              <td>{{description}}</td>
              <td>{{categoryName}}</td>
              <td>{{priceLabel}}</td>
              <td>
                <div class="d-flex justify-content-end flex-wrap gap-2">
                  <a href="/commerce/products/{{id}}/edit" class="btn btn-sm btn-outline-primary">Editar</a>
                  <a href="/commerce/products/{{id}}/delete" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{else}}
      <p class="text-muted mb-0 p-3">Aun no has creado productos en este comercio.</p>
      {{/if}}
    </div>
  </div>
</section>
