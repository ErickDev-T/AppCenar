<section class="py-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Mi perfil</h1>
  </div>

  {{#each successMessages}}
  <div class="alert alert-success py-2 mb-2">{{this}}</div>
  {{/each}}

  {{#if errors.length}}
  <div class="alert alert-danger py-2 mb-3">
    <ul class="mb-0">
      {{#each errors}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  <div class="card">
    <div class="card-body">
      <form action="/commerce/profile" method="post" enctype="multipart/form-data" class="row g-3" novalidate>
        <div class="col-12">
          {{#if profileImageUrl}}
          <div class="mb-2">
            <img
              src="{{profileImageUrl}}"
              alt="Logo actual del comercio"
              class="rounded"
              style="width: 90px; height: 90px; object-fit: cover;"
            />
          </div>
          {{/if}}

          <label for="profileImage" class="form-label">Logo del comercio (opcional)</label>
          <input id="profileImage" name="profileImage" type="file" class="form-control" accept="image/*" />
        </div>

        <div class="col-12 col-md-6">
          <label for="openingTime" class="form-label">Hora de apertura</label>
          <input
            id="openingTime"
            name="openingTime"
            type="time"
            class="form-control"
            value="{{formData.openingTime}}"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="closingTime" class="form-label">Hora de cierre</label>
          <input
            id="closingTime"
            name="closingTime"
            type="time"
            class="form-control"
            value="{{formData.closingTime}}"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="phone" class="form-label">Telefono</label>
          <input
            id="phone"
            name="phone"
            type="text"
            class="form-control"
            value="{{formData.phone}}"
            required
          />
        </div>

        <div class="col-12 col-md-6">
          <label for="email" class="form-label">Correo</label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-control"
            value="{{formData.email}}"
            required
          />
        </div>

        <div class="col-12 d-flex flex-wrap gap-2 mt-2">
          <a href="/commerce/dashboard" class="btn btn-outline-secondary">Volver al home</a>
          <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>
</section>
